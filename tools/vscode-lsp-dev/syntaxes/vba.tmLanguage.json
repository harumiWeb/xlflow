{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VBA",
  "scopeName": "source.vba",
  "patterns": [
    { "include": "#attribute" },
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#line-continuation" },
    { "include": "#declarations" },
    { "include": "#labels" },
    { "include": "#numbers" },
    { "include": "#dates" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#members" }
  ],
  "repository": {
    "attribute": {
      "name": "meta.attribute.vba",
      "begin": "^\\s*(Attribute)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
      "beginCaptures": {
        "1": { "name": "keyword.other.attribute.vba" },
        "2": { "name": "variable.other.attribute-name.vba" },
        "3": { "name": "keyword.operator.assignment.vba" }
      },
      "end": "$",
      "patterns": [
        { "include": "#strings" },
        { "include": "#constants" },
        { "include": "#numbers" }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.conditional.vba",
          "match": "^\\s*(#(?:If|ElseIf|Else|End\\s+If)\\b)(.*)$",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.vba" },
            "2": { "name": "meta.preprocessor.expression.vba" }
          }
        },
        {
          "name": "meta.preprocessor.constant.vba",
          "match": "^\\s*(#Const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.vba" },
            "2": { "name": "variable.other.constant.preprocessor.vba" },
            "3": { "name": "keyword.operator.assignment.vba" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.apostrophe.vba",
          "match": "'.*$"
        },
        {
          "name": "comment.line.rem.vba",
          "match": "(?i)(^|:)\\s*\\bRem\\b.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vba",
          "begin": "\"",
          "end": "\"(?!\")",
          "patterns": [
            {
              "name": "constant.character.escape.quote.vba",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "line-continuation": {
      "name": "punctuation.separator.continuation.line.vba",
      "match": "_\\s*$"
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.option.vba",
          "match": "(?i)^\\s*(Option)\\s+(Explicit|Base|Compare|Private\\s+Module)\\b",
          "captures": {
            "1": { "name": "keyword.other.option.vba" },
            "2": { "name": "keyword.other.option.value.vba" }
          }
        },
        {
          "name": "meta.procedure.vba",
          "match": "(?i)\\b(?:(Public|Private|Friend|Static)\\s+)?(Sub|Function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.vba" },
            "2": { "name": "storage.type.procedure.vba" },
            "3": { "name": "entity.name.function.vba" }
          }
        },
        {
          "name": "meta.property.vba",
          "match": "(?i)\\b(?:(Public|Private|Friend|Static)\\s+)?(Property)\\s+(Get|Let|Set)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.vba" },
            "2": { "name": "storage.type.property.vba" },
            "3": { "name": "storage.type.property.accessor.vba" },
            "4": { "name": "entity.name.function.property.vba" }
          }
        },
        {
          "name": "meta.declare.vba",
          "match": "(?i)\\b(?:(Public|Private)\\s+)?(Declare)\\s+(PtrSafe\\s+)?(Sub|Function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.vba" },
            "2": { "name": "storage.type.declare.vba" },
            "3": { "name": "storage.modifier.ptrsafe.vba" },
            "4": { "name": "storage.type.procedure.vba" },
            "5": { "name": "entity.name.function.external.vba" }
          }
        },
        {
          "name": "meta.type.vba",
          "match": "(?i)\\b(?:(Public|Private)\\s+)?(Type|Enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.visibility.vba" },
            "2": { "name": "storage.type.user-defined.vba" },
            "3": { "name": "entity.name.type.vba" }
          }
        },
        {
          "name": "meta.variable.declaration.vba",
          "match": "(?i)\\b(Public|Private|Friend|Dim|Static|Const|Global)\\b",
          "captures": {
            "1": { "name": "storage.type.variable.vba" }
          }
        },
        {
          "name": "storage.modifier.parameter.vba",
          "match": "(?i)\\b(ByVal|ByRef|Optional|ParamArray)\\b"
        },
        {
          "name": "keyword.other.as-new.vba",
          "match": "(?i)\\b(As|New|Lib|Alias|Implements)\\b"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.line-number.vba",
          "match": "^\\s*\\d+(?=\\s|$)"
        },
        {
          "name": "entity.name.label.vba",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "entity.name.label.vba" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.vba",
          "match": "(?i)\\b&H[0-9A-F]+(?:[&!#@]|\\^)?\\b"
        },
        {
          "name": "constant.numeric.octal.vba",
          "match": "(?i)\\b&O[0-7]+(?:[&!#@]|\\^)?\\b"
        },
        {
          "name": "constant.numeric.decimal.vba",
          "match": "(?i)(?:\\b\\d+(?:\\.\\d+)?|\\.\\d+)(?:E[+-]?\\d+)?(?:[%&!#@]|\\^)?\\b"
        }
      ]
    },
    "dates": {
      "name": "constant.other.date.vba",
      "match": "#[^#\\r\\n]+#"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.vba",
          "match": "(?i)\\b(True|False|Nothing|Null|Empty|Missing)\\b"
        },
        {
          "name": "constant.other.excel.vba",
          "match": "\\bxl[A-Za-z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "constant.other.office.vba",
          "match": "\\bmso[A-Za-z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "constant.other.msforms.vba",
          "match": "\\bfm[A-Za-z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "constant.other.vb.vba",
          "match": "\\bvb[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "support.constant.error.vba",
          "match": "(?i)\\b(vbObjectError)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.vba",
          "match": "(?i)\\b(If|Then|Else|ElseIf|End\\s+If|Select\\s+Case|Select|Case|End\\s+Select)\\b"
        },
        {
          "name": "keyword.control.loop.vba",
          "match": "(?i)\\b(For\\s+Each|For|Each|In|To|Step|Next|Do|Loop|While|Wend|Until|Exit\\s+For|Exit\\s+Do)\\b"
        },
        {
          "name": "keyword.control.flow.vba",
          "match": "(?i)\\b(Exit\\s+Sub|Exit\\s+Function|Exit\\s+Property|Exit|GoTo|GoSub|Return|Stop|End)\\b"
        },
        {
          "name": "keyword.control.error.vba",
          "match": "(?i)\\b(On\\s+Error|Resume\\s+Next|Resume|Err|Error)\\b"
        },
        {
          "name": "keyword.control.with.vba",
          "match": "(?i)\\b(With|End\\s+With)\\b"
        },
        {
          "name": "keyword.operator.word.vba",
          "match": "(?i)\\b(And|Or|Not|Xor|Eqv|Imp|Is|Like|Mod)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Call|Set|Let|Get|RaiseEvent|Event|Load|Unload|ReDim|Preserve|Erase|Open|Close|Input|Print|Write|Lock|Unlock|Name|Kill|MkDir|RmDir|ChDir|ChDrive)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.vba",
          "match": "(?i)\\b(Boolean|Byte|Currency|Date|Decimal|Double|Integer|Long|LongLong|LongPtr|Object|Single|String|Variant|Any)\\b"
        },
        {
          "name": "support.type.excel.vba",
          "match": "\\b(?:Excel\\.)?(Application|Workbook|Workbooks|Worksheet|Worksheets|Sheets|Range|Chart|ChartObject|ListObject|PivotTable|Shape|Window|Name|Names)\\b"
        },
        {
          "name": "support.type.com.vba",
          "match": "\\b(?:Scripting\\.)?(Dictionary|FileSystemObject|TextStream)\\b|\\b(?:ADODB\\.)?(Connection|Recordset)\\b|\\b(?:MSForms\\.)?(UserForm|Control|TextBox|ComboBox|CommandButton|Label)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.vba",
          "match": "<=|>=|<>|=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.vba",
          "match": "\\+|-|\\*\\*|\\*|/|\\\\|\\^|&"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "support.function.builtin.vba",
          "match": "(?i)\\b(CreateObject|GetObject|MsgBox|InputBox|Debug\\.Print|Debug|CStr|CLng|CInt|CBool|CDate|CDbl|CSng|CVar|Val|Len|Left|Right|Mid|Trim|LTrim|RTrim|InStr|Replace|Split|Join|Array|UBound|LBound|IsNull|IsEmpty|IsNumeric|TypeName)\\b"
        },
        {
          "name": "variable.language.excel.vba",
          "match": "\\b(Application|ThisWorkbook|ActiveWorkbook|ActiveSheet|Workbooks|Worksheets|Sheets|Range|Cells|Rows|Columns)\\b"
        },
        {
          "name": "variable.other.member.vba",
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.dot.vba" },
            "2": { "name": "variable.other.member.vba" }
          }
        }
      ]
    }
  }
}
