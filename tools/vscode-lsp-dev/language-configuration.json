{
  "comments": {
    "lineComment": "'"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "(", "close": ")", "notIn": ["string", "comment"] },
    { "open": "[", "close": "]", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@%\\^&*()\\-=+\\[{\\]}\\\\|;:'\\\",.<>/?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*((Public|Private|Friend|Static)\\s+)?(Sub|Function|Property\\s+(Get|Let|Set))\\b|^\\s*If\\b.*\\bThen\\s*$|^\\s*(Else|ElseIf\\b.*\\bThen\\s*$)|^\\s*(For|For\\s+Each|Do|While|With|Select\\s+Case|Type|Enum)\\b|^\\s*#If\\b.*\\bThen\\s*$",
    "decreaseIndentPattern": "^\\s*(End\\s+(Sub|Function|Property|If|Select|With|Type|Enum)|Next\\b|Loop\\b|Wend\\b|Else\\b|ElseIf\\b|Case\\b|#Else\\b|#ElseIf\\b|#End\\s+If\\b)"
  },
  "folding": {
    "markers": {
      "start": "^\\s*('\\s*)?#Region\\b",
      "end": "^\\s*('\\s*)?#End\\s+Region\\b"
    }
  }
}
