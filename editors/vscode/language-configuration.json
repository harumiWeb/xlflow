{
  "comments": {
    "lineComment": "'"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "onEnterRules": [
    {
      "beforeText": "^\\s*'''(?:\\s.*)?$",
      "action": {
        "indent": "none",
        "appendText": "''' "
      }
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*#Region\\b",
      "end": "^\\s*#End Region\\b"
    }
  }
}
