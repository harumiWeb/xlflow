{
  "name": "xlflow-vscode",
  "displayName": "%extension.displayName%",
  "version": "0.1.0",
  "private": true,
  "description": "%extension.description%",
  "categories": [
    "Formatters",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "excel",
    "language server",
    "lsp",
    "macro",
    "vba",
    "xlflow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harumiWeb/xlflow.git",
    "directory": "editors/vscode"
  },
  "publisher": "harumiweb",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "pnpm run check && pnpm run bundle",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "bundle": "node esbuild.js",
    "package": "vsce package --no-dependencies",
    "test": "pnpm run compile && node ./dist/test/runTest.js",
    "lint": "oxlint ."
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "1.91.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "typescript": "^5.9.0"
  },
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "xlflow.path": {
          "type": "string",
          "default": "xlflow",
          "description": "%configuration.xlflow.path.description%"
        },
        "xlflow.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.lsp.enabled.description%"
        },
        "xlflow.lsp.logFile": {
          "type": "string",
          "default": ".xlflow/lsp.log",
          "description": "%configuration.xlflow.lsp.logFile.description%"
        },
        "xlflow.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "messages",
          "description": "%configuration.xlflow.lsp.trace.server.description%"
        },
        "xlflow.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.codeLens.enabled.description%"
        },
        "xlflow.codeLens.runProcedure": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.codeLens.runProcedure.description%"
        },
        "xlflow.codeLens.runTests": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.codeLens.runTests.description%"
        },
        "xlflow.codeLens.userFormEvents": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.xlflow.codeLens.userFormEvents.description%"
        },
        "xlflow.run.saveBeforeRun": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.run.saveBeforeRun.description%"
        },
        "xlflow.completion.triggerSuggestInStatements": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.completion.triggerSuggestInStatements.description%"
        },
        "xlflow.completion.progIdsInStrings": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.completion.progIdsInStrings.description%"
        },
        "xlflow.testing.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.xlflow.testing.autoDiscover.description%"
        }
      }
    },
    "configurationDefaults": {
      "[vba]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "on"
        },
        "editor.autoClosingBrackets": "always",
        "editor.autoClosingQuotes": "always",
        "editor.semanticHighlighting.enabled": true,
        "editor.snippetSuggestions": "top",
        "editor.suggest.snippetsPreventQuickSuggestions": false
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xlflow",
          "title": "%viewsContainer.xlflow.title%",
          "icon": "images/activity-icon.svg"
        }
      ]
    },
    "views": {
      "xlflow": [
        {
          "id": "xlflow.setup",
          "name": "%view.setup.name%",
          "when": "!xlflow.projectReady"
        },
        {
          "id": "xlflow.project",
          "name": "%view.project.name%",
          "when": "xlflow.projectReady"
        },
        {
          "id": "xlflow.modules",
          "name": "%view.modules.name%",
          "when": "xlflow.projectReady"
        },
        {
          "id": "xlflow.userForms",
          "name": "%view.userForms.name%",
          "when": "xlflow.projectReady"
        },
        {
          "id": "xlflow.tests",
          "name": "%view.tests.name%",
          "when": "xlflow.projectReady"
        }
      ]
    },
    "commands": [
      {
        "command": "xlflow.restartLanguageServer",
        "title": "%command.restartLanguageServer.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.checkEnvironment",
        "title": "%command.checkEnvironment.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.openInstallGuide",
        "title": "%command.openInstallGuide.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.configurePath",
        "title": "%command.configurePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.retryCliDetection",
        "title": "%command.retryCliDetection.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.newProject",
        "title": "%command.newProject.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.initProject",
        "title": "%command.initProject.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.skillInstall",
        "title": "%command.skillInstall.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.moduleInstall",
        "title": "%command.moduleInstall.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.newModule",
        "title": "%command.newModule.title%",
        "category": "%command.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "xlflow.newStandardModule",
        "title": "%command.newStandardModule.title%",
        "category": "%command.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "xlflow.newClassModule",
        "title": "%command.newClassModule.title%",
        "category": "%command.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "xlflow.newUserForm",
        "title": "%command.newUserForm.title%",
        "category": "%command.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "xlflow.pull",
        "title": "%command.pull.title%",
        "category": "%command.category%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "xlflow.push",
        "title": "%command.push.title%",
        "category": "%command.category%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "xlflow.runMacro",
        "title": "%command.runMacro.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.runProcedure",
        "title": "%command.runProcedure.title%",
        "category": "%command.category%",
        "icon": "$(play)"
      },
      {
        "command": "xlflow.runTestProcedure",
        "title": "%command.runTestProcedure.title%",
        "category": "%command.category%",
        "icon": "$(beaker)"
      },
      {
        "command": "xlflow.test",
        "title": "%command.test.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.lintWorkspace",
        "title": "%command.lintWorkspace.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.formatDocument",
        "title": "%command.formatDocument.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.formatProject",
        "title": "%command.formatProject.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.saveWorkbook",
        "title": "%command.saveWorkbook.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.sessionStart",
        "title": "%command.sessionStart.title%",
        "category": "%command.category%",
        "icon": "$(play)",
        "enablement": "xlflow.sessionStartEnabled"
      },
      {
        "command": "xlflow.sessionStatus",
        "title": "%command.sessionStatus.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.sessionRestart",
        "title": "%command.sessionRestart.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.sessionStop",
        "title": "%command.sessionStop.title%",
        "category": "%command.category%",
        "icon": "$(debug-stop)",
        "enablement": "xlflow.sessionStopEnabled"
      },
      {
        "command": "xlflow.openOutput",
        "title": "%command.openOutput.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.refreshProject",
        "title": "%command.refreshProject.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "xlflow.refreshModules",
        "title": "%command.refreshModules.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "xlflow.collapseModules",
        "title": "%command.collapseModules.title%",
        "category": "%command.category%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "xlflow.refreshUserForms",
        "title": "%command.refreshUserForms.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "xlflow.collapseUserForms",
        "title": "%command.collapseUserForms.title%",
        "category": "%command.category%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "xlflow.refreshTests",
        "title": "%command.refreshTests.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "xlflow.runAllTests",
        "title": "%command.runAllTests.title%",
        "category": "%command.category%",
        "icon": "$(beaker)"
      },
      {
        "command": "xlflow.runDoctor",
        "title": "%command.runDoctor.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.sessionToggle",
        "title": "%command.sessionToggle.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.setupActions",
        "title": "%command.setupActions.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.openDocumentation",
        "title": "%command.openDocumentation.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.openModule",
        "title": "%command.openModule.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.renameModule",
        "title": "%command.renameModule.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.deleteModule",
        "title": "%command.deleteModule.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.revealSourceFile",
        "title": "%command.revealSourceFile.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyModuleName",
        "title": "%command.copyModuleName.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyRelativePath",
        "title": "%command.copyRelativePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyProcedureName",
        "title": "%command.copyProcedureName.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyQualifiedName",
        "title": "%command.copyQualifiedName.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.openProcedure",
        "title": "%command.openProcedure.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.openUserFormArtifact",
        "title": "%command.openUserFormArtifact.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.renameUserForm",
        "title": "%command.renameUserForm.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.deleteUserForm",
        "title": "%command.deleteUserForm.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.revealUserFormSource",
        "title": "%command.revealUserFormSource.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyUserFormName",
        "title": "%command.copyUserFormName.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlflow.copyUserFormRelativePath",
        "title": "%command.copyUserFormRelativePath.title%",
        "category": "%command.category%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xlflow.refreshProject",
          "when": "view == xlflow.project",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.pull",
          "when": "view == xlflow.project",
          "group": "navigation@2"
        },
        {
          "command": "xlflow.push",
          "when": "view == xlflow.project",
          "group": "navigation@3"
        },
        {
          "command": "xlflow.sessionStart",
          "when": "view == xlflow.project && xlflow.sessionStartEnabled",
          "group": "navigation@4"
        },
        {
          "command": "xlflow.sessionStop",
          "when": "view == xlflow.project && xlflow.sessionStopEnabled",
          "group": "navigation@5"
        },
        {
          "command": "xlflow.newModule",
          "when": "view == xlflow.modules",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.refreshModules",
          "when": "view == xlflow.modules",
          "group": "navigation@2"
        },
        {
          "command": "xlflow.collapseModules",
          "when": "view == xlflow.modules",
          "group": "navigation@3"
        },
        {
          "command": "xlflow.newUserForm",
          "when": "view == xlflow.userForms",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.refreshUserForms",
          "when": "view == xlflow.userForms",
          "group": "navigation@2"
        },
        {
          "command": "xlflow.collapseUserForms",
          "when": "view == xlflow.userForms",
          "group": "navigation@3"
        },
        {
          "command": "xlflow.runAllTests",
          "when": "view == xlflow.tests",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.refreshTests",
          "when": "view == xlflow.tests",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "xlflow.newModule",
          "when": "xlflow.projectReady"
        },
        {
          "command": "xlflow.newStandardModule",
          "when": "xlflow.projectReady"
        },
        {
          "command": "xlflow.newClassModule",
          "when": "xlflow.projectReady"
        },
        {
          "command": "xlflow.newUserForm",
          "when": "xlflow.projectReady"
        }
      ],
      "view/item/context": [
        {
          "command": "xlflow.openModule",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class|document)$/",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.renameModule",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class)$/",
          "group": "2_workspace@1"
        },
        {
          "command": "xlflow.deleteModule",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class)$/",
          "group": "2_workspace@2"
        },
        {
          "command": "xlflow.revealSourceFile",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class|document)$/",
          "group": "3_file@1"
        },
        {
          "command": "xlflow.copyModuleName",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class|document)$/",
          "group": "4_copy@1"
        },
        {
          "command": "xlflow.copyRelativePath",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.module\\.(standard|class|document)$/",
          "group": "4_copy@2"
        },
        {
          "command": "xlflow.runProcedure",
          "when": "view == xlflow.modules && viewItem == xlflow.procedure",
          "group": "inline@1"
        },
        {
          "command": "xlflow.runTestProcedure",
          "when": "view == xlflow.modules && viewItem == xlflow.testProcedure",
          "group": "inline@1"
        },
        {
          "command": "xlflow.runTestProcedure",
          "when": "view == xlflow.tests && viewItem == xlflow.testWithSource",
          "group": "inline@1"
        },
        {
          "command": "xlflow.openProcedure",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.(procedure|testProcedure|procedureStatic)$/",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.runProcedure",
          "when": "view == xlflow.modules && viewItem == xlflow.procedure",
          "group": "2_run@1"
        },
        {
          "command": "xlflow.runTestProcedure",
          "when": "view == xlflow.modules && viewItem == xlflow.testProcedure",
          "group": "2_run@1"
        },
        {
          "command": "xlflow.copyProcedureName",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.(procedure|testProcedure|procedureStatic)$/",
          "group": "4_copy@1"
        },
        {
          "command": "xlflow.copyQualifiedName",
          "when": "view == xlflow.modules && viewItem =~ /^xlflow\\.(procedure|testProcedure|procedureStatic)$/",
          "group": "4_copy@2"
        },
        {
          "command": "xlflow.renameUserForm",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userForm\\./",
          "group": "2_workspace@1"
        },
        {
          "command": "xlflow.deleteUserForm",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userForm\\./",
          "group": "2_workspace@2"
        },
        {
          "command": "xlflow.revealUserFormSource",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userForm\\./",
          "group": "3_file@1"
        },
        {
          "command": "xlflow.copyUserFormName",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userForm\\./",
          "group": "4_copy@1"
        },
        {
          "command": "xlflow.copyUserFormRelativePath",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userForm\\./",
          "group": "4_copy@2"
        },
        {
          "command": "xlflow.openUserFormArtifact",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userFormArtifact\\./",
          "group": "navigation@1"
        },
        {
          "command": "xlflow.revealUserFormSource",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userFormArtifact\\./",
          "group": "3_file@1"
        },
        {
          "command": "xlflow.copyUserFormRelativePath",
          "when": "view == xlflow.userForms && viewItem =~ /^xlflow\\.userFormArtifact\\./",
          "group": "4_copy@1"
        }
      ]
    },
    "languages": [
      {
        "id": "vba",
        "aliases": [
          "VBA",
          "Visual Basic for Applications"
        ],
        "extensions": [
          ".bas",
          ".cls",
          ".frm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vba",
        "scopeName": "source.vba",
        "path": "./syntaxes/vba.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "vba",
        "scopes": {
          "namespace": [
            "entity.name.namespace.vba"
          ],
          "type": [
            "entity.name.type.vba",
            "support.type.vba"
          ],
          "class": [
            "entity.name.type.class.vba",
            "support.type.excel.vba",
            "support.type.com.vba"
          ],
          "enum": [
            "entity.name.type.enum.vba"
          ],
          "interface": [
            "entity.name.type.interface.vba"
          ],
          "function": [
            "entity.name.function.vba",
            "support.function.builtin.vba"
          ],
          "method": [
            "entity.name.function.vba",
            "variable.other.member.vba"
          ],
          "property": [
            "entity.name.function.property.vba",
            "variable.other.property.vba"
          ],
          "enumMember": [
            "constant.other.vba"
          ],
          "event": [
            "entity.name.function.event.vba"
          ],
          "variable": [
            "variable.other.local.vba",
            "variable.other.vba"
          ],
          "parameter": [
            "variable.parameter.vba"
          ],
          "keyword": [
            "keyword.control.vba",
            "keyword.other.vba"
          ],
          "modifier": [
            "storage.modifier.vba"
          ],
          "operator": [
            "keyword.operator.vba"
          ],
          "string": [
            "string.quoted.double.vba"
          ],
          "number": [
            "constant.numeric.vba"
          ],
          "comment": [
            "comment.line.vba"
          ]
        }
      }
    ]
  },
  "activationEvents": [
    "onCommand:xlflow.checkEnvironment",
    "onCommand:xlflow.collapseModules",
    "onCommand:xlflow.collapseUserForms",
    "onCommand:xlflow.configurePath",
    "onCommand:xlflow.copyModuleName",
    "onCommand:xlflow.copyProcedureName",
    "onCommand:xlflow.copyQualifiedName",
    "onCommand:xlflow.copyRelativePath",
    "onCommand:xlflow.copyUserFormName",
    "onCommand:xlflow.copyUserFormRelativePath",
    "onCommand:xlflow.deleteModule",
    "onCommand:xlflow.deleteUserForm",
    "onCommand:xlflow.formatDocument",
    "onCommand:xlflow.formatProject",
    "onCommand:xlflow.initProject",
    "onCommand:xlflow.lintWorkspace",
    "onCommand:xlflow.moduleInstall",
    "onCommand:xlflow.newClassModule",
    "onCommand:xlflow.newModule",
    "onCommand:xlflow.newProject",
    "onCommand:xlflow.newStandardModule",
    "onCommand:xlflow.newUserForm",
    "onCommand:xlflow.openDocumentation",
    "onCommand:xlflow.openInstallGuide",
    "onCommand:xlflow.openModule",
    "onCommand:xlflow.openOutput",
    "onCommand:xlflow.openProcedure",
    "onCommand:xlflow.openUserFormArtifact",
    "onCommand:xlflow.pull",
    "onCommand:xlflow.push",
    "onCommand:xlflow.refreshModules",
    "onCommand:xlflow.refreshProject",
    "onCommand:xlflow.refreshTests",
    "onCommand:xlflow.refreshUserForms",
    "onCommand:xlflow.renameModule",
